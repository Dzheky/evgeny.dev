# Buttondown API key — used in SubscribeForm for newsletter subscriptions
# This is a PUBLIC key (browser-facing). Buttondown subscriber-write tokens
# have limited scope: they can only add subscribers, not read them or send emails.
PUBLIC_BUTTONDOWN_API_KEY=your_buttondown_api_key_here

# Resend API key — used for optional custom welcome emails via Buttondown webhook
# This is a SERVER-ONLY key. Never expose this in client-side code.
RESEND_API_KEY=your_resend_api_key_here
