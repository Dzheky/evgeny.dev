---
const currentPath = Astro.url.pathname

const isActive = (path: string) => {
  if (path === '/') return currentPath === '/'
  return currentPath.startsWith(path)
}

const aboutActive = isActive('/') && !isActive('/blog')
const blogActive = isActive('/blog')
---

<nav class="nav" aria-label="Main navigation">
  <a href="/" class:list={['nav-link', { active: aboutActive }]} aria-current={aboutActive ? 'page' : undefined}>
    about
    {aboutActive && <span class="indicator" transition:name="nav-indicator"></span>}
  </a>
  <a href="/blog" class:list={['nav-link', { active: blogActive }]} aria-current={blogActive ? 'page' : undefined}>
    blog
    {blogActive && <span class="indicator" transition:name="nav-indicator"></span>}
  </a>
</nav>

<script>
  function init() {
    document.querySelectorAll<HTMLAnchorElement>('.nav-link[aria-current="page"]').forEach((link) => {
      link.addEventListener('click', (e) => e.preventDefault())
    })
  }
  init()
  document.addEventListener('astro:page-load', init)
</script>

<style>
  .nav {
    display: grid;
    grid-template-columns: auto auto;
    align-items: center;
    gap: 1.8rem;
    font-size: 1.8rem;
    font-weight: 500;

    @media (max-width: 750px) {
      display: none;
    }
  }

  .nav-link {
    position: relative;
    text-decoration: none;
    color: var(--color-primary);
    padding-bottom: 0.3rem;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -0.2rem;
    left: 0;
    width: 0;
    height: 0.2rem;
    background-color: var(--color-orange);
    transition: width ease-in-out 200ms;
  }

  .nav-link:hover::after {
    width: 100%;
    opacity: 0.3;
  }

  .indicator {
    position: absolute;
    bottom: -0.2rem;
    left: 0;
    width: 100%;
    height: 0.2rem;
    background-color: var(--color-orange);
  }
</style>
