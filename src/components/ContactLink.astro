<style>
  .contact-link {
    display: grid;
    font-size: 1.6rem;
    font-weight: bold;
    color: var(--color-primary);
    text-decoration: none;
    grid-template-columns: 2.2rem auto;
    gap: 1.2rem;
    align-items: center;
    justify-content: start;
  }

  .contact-link svg {
    width: 2.2rem;
    height: 2.2rem;
  }

  .contact-link:hover .contact-text {
    border-bottom: 0.2rem solid var(--color-orange);
  }
</style>
